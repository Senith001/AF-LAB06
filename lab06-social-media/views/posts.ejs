<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social Feed</title>
  <style>
    :root {
      --bg-color: #f0f2f5;
      --card-bg: #ffffff;
      --text-main: #1c1e21;
      --text-secondary: #65676b;
      --accent-color: #1877f2;
    }

    body {
      font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
      margin: 0;
      padding: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    h1 {
      color: var(--text-main);
      margin-bottom: 30px;
      font-weight: 800;
    }

    .feed-container {
      width: 100%;
      max-width: 600px;
    }

    .post {
      background: var(--card-bg);
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
      padding: 20px;
      margin-bottom: 20px;
      transition: transform 0.2s ease;
    }

    .post:hover {
      transform: translateY(-2px);
    }

    .post-header {
      margin-bottom: 15px;
    }

    .post h2 {
      margin: 0;
      font-size: 1.25rem;
      color: var(--text-main);
    }

    .author-tag {
      display: block;
      color: var(--accent-color);
      font-weight: 600;
      font-size: 0.9rem;
      margin-top: 4px;
    }

    .post-content {
      font-size: 1rem;
      line-height: 1.5;
      margin-bottom: 15px;
    }

    .post-image {
      width: 100%;
      max-height: 400px;
      object-fit: cover;
      border-radius: 8px;
      margin-top: 10px;
    }

    .empty-state {
      text-align: center;
      color: var(--text-secondary);
      margin-top: 50px;
    }
  </style>
</head>
<body>

  <h1>All Posts</h1>

  <div class="feed-container">
    <% if (posts.length === 0) { %>
      <div class="empty-state">
        <p>No posts available yet. Be the first to share something!</p>
      </div>
    <% } %>

    <% posts.forEach(post => { %>
      <div class="post">
        <div class="post-header">
          <h2><%= post.title %></h2>
          <span class="author-tag">@<%= post.author %></span>
        </div>
        
        <p class="post-content"><%= post.content %></p>

        <% if (post.image) { %>
          <img src="<%= post.image %>" alt="Post image" class="post-image">
        <% } %>
      </div>
    <% }) %>
  </div>

</body>
</html>